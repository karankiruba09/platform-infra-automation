# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
*.code-workspace

# --- Build / runtime / dependencies ---
bin/
build/
dist/
node_modules/
__pycache__/
*.pyc
.venv/
venv/
*.log

# --- Per-tool convention: sensitive inputs and generated outputs ---
# Anything a user supplies (vault files, inventories, vCenter lists, deploy
# configs) lives under inputs/. Anything a tool generates (reports, logs,
# dashboards) lives under output/. Both are ignored by default; only
# committed scaffolding (examples, j2 templates, .gitkeep) is allowed back in.
**/inputs/
**/output/
!**/inputs/.gitkeep
!**/inputs/*.example
!**/inputs/*.example.*
!**/inputs/*.j2
!**/output/.gitkeep

# --- Catch-all secrets (defense in depth) ---
.env
*.env
*.pem
*.key
*.p12
*.pfx
*.clixml
*cred.xml
*credential.xml

# --- Claude Code ---
.claude/
